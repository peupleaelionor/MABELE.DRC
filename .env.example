# =============================================================================
# MABELE — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# --- Database ---
DATABASE_URL="postgresql://mabele:mabele_password@localhost:5432/mabele_db"

# --- NextAuth ---
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# --- OTP / SMS ---
# Supported: Africa's Talking, Vonage, Twilio
SMS_PROVIDER="africas_talking"
AFRICAS_TALKING_API_KEY="your-at-api-key"
AFRICAS_TALKING_USERNAME="sandbox"

# Twilio (alternative)
TWILIO_ACCOUNT_SID="your-twilio-sid"
TWILIO_AUTH_TOKEN="your-twilio-token"
TWILIO_PHONE_NUMBER="+1234567890"

# --- Redis (session & cache) ---
REDIS_URL="redis://localhost:6379"

# --- Meilisearch (full-text search) ---
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="your-meilisearch-master-key"

# --- File Storage ---
# Supported: cloudinary, s3, local
STORAGE_PROVIDER="cloudinary"
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# S3 (alternative)
AWS_ACCESS_KEY_ID="your-aws-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret"
AWS_BUCKET_NAME="mabele-uploads"
AWS_REGION="af-south-1"

# --- Mobile Money ---
# Airtel Money
AIRTEL_CLIENT_ID="your-airtel-client-id"
AIRTEL_CLIENT_SECRET="your-airtel-client-secret"
AIRTEL_BASE_URL="https://openapi.airtel.africa"

# M-Pesa / Vodacom
MPESA_CONSUMER_KEY="your-mpesa-key"
MPESA_CONSUMER_SECRET="your-mpesa-secret"
MPESA_PASSKEY="your-mpesa-passkey"
MPESA_SHORTCODE="your-shortcode"

# Orange Money
ORANGE_CLIENT_ID="your-orange-client-id"
ORANGE_CLIENT_SECRET="your-orange-client-secret"

# --- Maps ---
NEXT_PUBLIC_MAPBOX_TOKEN="pk.your-mapbox-token"
GOOGLE_MAPS_API_KEY="your-google-maps-key"

# --- Analytics ---
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_POSTHOG_KEY="phc_your-posthog-key"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# --- App Config ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="MABELE"
NEXT_PUBLIC_APP_ENV="development"

# --- Email ---
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="noreply@mabele.cd"
