generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ─────────────────────────────────────────────────────────────

model User {
  id         String   @id @default(cuid())
  phone      String   @unique
  email      String?  @unique
  name       String
  avatar     String?
  role       Role     @default(USER)
  province   String?
  ville      String?
  isVerified Boolean  @default(false)
  locale     String   @default("fr")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  immoListings         ImmoListing[]
  jobPostings          JobPosting[]
  marketItems          MarketItem[]
  agriProducts         AgriProduct[]
  invoices             Invoice[]
  favorites            Favorite[]
  reviews              Review[]
  tontineGroups        TontineGroupMember[]
  notifications        Notification[]
  listings             Listing[]
  conversations        ConversationParticipant[]
  sentMessages         Message[]
  trustProfile         TrustProfile?
  reports              Report[]
  auditLogs            AuditLog[]
  paymentIntents       PaymentIntent[]
  analyticsEvents      AnalyticsEvent[]
  subscriptions        Subscription[]
  verifications        UserVerification[]
  wallet               Wallet?
  idempotencyKeys      IdempotencyKey[]
  domainEvents         DomainEvent[]
  referrals            Referral[]        @relation("Referrer")
  referredBy           Referral?         @relation("Referred")
  consentLogs          ConsentLog[]
}

enum Role {
  USER
  VERIFIED_USER
  MERCHANT
  AGENT_IMMO
  EMPLOYER
  FARMER
  AGENT
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

// ─── KYC & Verification ───────────────────────────────────────────────────────

enum VerificationType {
  PHONE
  EMAIL
  NATIONAL_ID
  BUSINESS_REG
  SELFIE
  ADDRESS
}

enum VerificationStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

model UserVerification {
  id          String             @id @default(cuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id])
  type        VerificationType
  status      VerificationStatus @default(PENDING)
  documentUrl String?
  selfieUrl   String?
  data        Json?
  reviewedBy  String?
  reviewNote  String?
  expiresAt   DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([userId, type])
  @@index([status])
}

// ─── Billing: Plans ──────────────────────────────────────────────────────────

enum PlanTier {
  FREE
  STARTER
  BUSINESS
  ENTERPRISE
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  YEARLY
}

model Plan {
  id            String       @id @default(cuid())
  key           String       @unique
  name          String
  tier          PlanTier
  description   String?
  priceMonthly  Float        @default(0)
  priceYearly   Float        @default(0)
  devise        String       @default("USD")
  features      Json
  limits        Json
  isActive      Boolean      @default(true)
  isPublic      Boolean      @default(true)
  sortOrder     Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  subscriptions Subscription[]

  @@index([tier, isActive])
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

model Subscription {
  id                String             @id @default(cuid())
  userId            String
  user              User               @relation(fields: [userId], references: [id])
  planId            String
  plan              Plan               @relation(fields: [planId], references: [id])
  status            SubscriptionStatus @default(ACTIVE)
  cycle             BillingCycle       @default(MONTHLY)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean           @default(false)
  cancelledAt        DateTime?
  trialEnd           DateTime?
  providerRef        String?
  metadata           Json?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  billingEvents BillingEvent[]

  @@index([userId, status])
  @@index([currentPeriodEnd])
}

// ─── Billing Events (audit trail) ────────────────────────────────────────────

enum BillingEventType {
  SUBSCRIPTION_CREATED
  SUBSCRIPTION_RENEWED
  SUBSCRIPTION_CANCELLED
  SUBSCRIPTION_EXPIRED
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  REFUND_ISSUED
  TRIAL_STARTED
  TRIAL_ENDED
  PLAN_UPGRADED
  PLAN_DOWNGRADED
  INVOICE_GENERATED
  BOOST_PURCHASED
  VERIFICATION_CHARGED
}

model BillingEvent {
  id             String           @id @default(cuid())
  subscriptionId String?
  subscription   Subscription?    @relation(fields: [subscriptionId], references: [id])
  paymentIntentId String?
  type           BillingEventType
  amount         Float?
  devise         String?
  metadata       Json?
  createdAt      DateTime         @default(now())

  @@index([subscriptionId])
  @@index([type])
  @@index([createdAt])
}

// ─── Wallet ──────────────────────────────────────────────────────────────────

enum WalletStatus {
  ACTIVE
  FROZEN
  CLOSED
}

model Wallet {
  id        String       @id @default(cuid())
  userId    String       @unique
  user      User         @relation(fields: [userId], references: [id])
  balance   Float        @default(0)
  currency  String       @default("USD")
  status    WalletStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  transactions WalletTransaction[]
}

enum WalletTxType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER_IN
  TRANSFER_OUT
  PAYMENT
  REFUND
  FEE
  BONUS
  TONTINE_CONTRIBUTION
  TONTINE_PAYOUT
}

model WalletTransaction {
  id          String       @id @default(cuid())
  walletId    String
  wallet      Wallet       @relation(fields: [walletId], references: [id])
  type        WalletTxType
  amount      Float
  currency    String       @default("USD")
  balanceBefore Float
  balanceAfter  Float
  description String?
  reference   String?
  metadata    Json?
  createdAt   DateTime     @default(now())

  @@index([walletId, createdAt])
  @@index([reference])
}

// ─── Idempotency ─────────────────────────────────────────────────────────────

model IdempotencyKey {
  id         String   @id @default(cuid())
  key        String   @unique
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  endpoint   String
  response   Json?
  status     Int?
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  @@index([key])
  @@index([expiresAt])
}

// ─── Webhooks ────────────────────────────────────────────────────────────────

enum WebhookEventStatus {
  RECEIVED
  PROCESSED
  FAILED
  SKIPPED
}

model WebhookEvent {
  id           String             @id @default(cuid())
  provider     String
  eventType    String
  payload      Json
  signature    String?
  status       WebhookEventStatus @default(RECEIVED)
  processedAt  DateTime?
  errorMessage String?
  retries      Int                @default(0)
  createdAt    DateTime           @default(now())

  @@index([provider, eventType])
  @@index([status])
  @@index([createdAt])
}

// ─── Domain Events ────────────────────────────────────────────────────────────

model DomainEvent {
  id         String   @id @default(cuid())
  type       String
  aggregateId String?
  aggregateType String?
  payload    Json
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  processedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([type])
  @@index([aggregateId, aggregateType])
  @@index([createdAt])
}

// ─── Referrals ────────────────────────────────────────────────────────────────

model Referral {
  id          String   @id @default(cuid())
  referrerId  String
  referrer    User     @relation("Referrer", fields: [referrerId], references: [id])
  referredId  String   @unique
  referred    User     @relation("Referred", fields: [referredId], references: [id])
  code        String
  rewarded    Boolean  @default(false)
  rewardedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([referrerId])
  @@index([code])
}

// ─── Consent Logs (GDPR/compliance) ──────────────────────────────────────────

model ConsentLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String
  granted     Boolean
  version     String
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId, type])
}

// ─── Legacy Vertical Models ───────────────────────────────────────────────────

model ImmoListing {
  id           String        @id @default(cuid())
  type         ImmoType
  action       ImmoAction
  titre        String
  description  String
  prix         Float
  devise       String        @default("USD")
  ville        String
  quartier     String
  province     String
  adresse      String?
  latitude     Float?
  longitude    Float?
  surface      Int
  chambres     Int           @default(0)
  sallesBain   Int           @default(0)
  etage        Int?
  meuble       Boolean       @default(false)
  parking      Boolean       @default(false)
  gardien      Boolean       @default(false)
  electrogen   Boolean       @default(false)
  eauChaude    Boolean       @default(false)
  internet     Boolean       @default(false)
  titreVerifie Boolean       @default(false)
  numFoncier   String?
  photos       String[]
  video360     String?
  status       ListingStatus @default(ACTIVE)
  boosted      Boolean       @default(false)
  boostedUntil DateTime?
  vues         Int           @default(0)
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  favorites    Favorite[]
  reviews      Review[]

  @@index([ville, type, action])
  @@index([prix])
  @@index([boosted, boostedUntil])
}

enum ImmoType {
  APPARTEMENT
  MAISON
  VILLA
  DUPLEX
  TERRAIN
  BUREAU
  LOCAL_COMMERCIAL
  ENTREPOT
}

enum ImmoAction {
  LOCATION
  VENTE
}

enum ListingStatus {
  ACTIVE
  PENDING
  SOLD
  RENTED
  EXPIRED
  FLAGGED
  DRAFT
}

model JobPosting {
  id           String           @id @default(cuid())
  titre        String
  description  String
  entreprise   String
  logo         String?
  ville        String
  province     String
  type         JobType
  categorie    String
  salaireMin   Float?
  salaireMax   Float?
  devise       String           @default("USD")
  experience   String?
  competences  String[]
  urgent       Boolean          @default(false)
  remote       Boolean          @default(false)
  status       ListingStatus    @default(ACTIVE)
  boosted      Boolean          @default(false)
  boostedUntil DateTime?
  vues         Int              @default(0)
  candidatures Int              @default(0)
  userId       String
  user         User             @relation(fields: [userId], references: [id])
  createdAt    DateTime         @default(now())
  expiresAt    DateTime?
  applications JobApplication[]
  favorites    Favorite[]

  @@index([ville, categorie, type])
}

enum JobType {
  CDI
  CDD
  FREELANCE
  STAGE
  INTERIM
}

model JobApplication {
  id        String            @id @default(cuid())
  jobId     String
  job       JobPosting        @relation(fields: [jobId], references: [id])
  nom       String
  email     String
  phone     String
  cv        String?
  message   String?
  status    ApplicationStatus @default(PENDING)
  createdAt DateTime          @default(now())
}

enum ApplicationStatus {
  PENDING
  REVIEWED
  SHORTLISTED
  REJECTED
  HIRED
}

model MarketItem {
  id          String        @id @default(cuid())
  nom         String
  description String
  categorie   String
  prix        Float
  devise      String        @default("USD")
  etat        ItemCondition
  ville       String
  province    String
  photos      String[]
  status      ListingStatus @default(ACTIVE)
  boosted     Boolean       @default(false)
  boostedUntil DateTime?
  vues        Int           @default(0)
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  createdAt   DateTime      @default(now())
  favorites   Favorite[]

  @@index([categorie, ville])
}

enum ItemCondition {
  NEUF
  OCCASION
  RECONDITIONNE
}

model AgriProduct {
  id           String   @id @default(cuid())
  produit      String
  description  String?
  quantite     Float
  unite        String
  prixUnitaire Float
  devise       String   @default("USD")
  ville        String
  province     String
  disponible   Boolean  @default(true)
  bio          Boolean  @default(false)
  certifie     Boolean  @default(false)
  photos       String[]
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())

  @@index([produit, ville])
}

model Invoice {
  id          String        @id @default(cuid())
  numero      String        @unique
  clientNom   String
  clientPhone String?
  clientEmail String?
  items       Json
  sousTotal   Float
  taxe        Float         @default(0)
  total       Float
  devise      String        @default("USD")
  status      InvoiceStatus @default(DRAFT)
  paidAt      DateTime?
  paidVia     String?
  dueDate     DateTime?
  notes       String?
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userId, status])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

model TontineGroup {
  id          String               @id @default(cuid())
  nom         String
  description String?
  montant     Float
  devise      String               @default("USD")
  frequence   TontineFrequency
  maxMembres  Int
  currentRound Int                 @default(0)
  startDate   DateTime?
  endDate     DateTime?
  isActive    Boolean              @default(true)
  members     TontineGroupMember[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model TontineGroupMember {
  id        String       @id @default(cuid())
  groupId   String
  group     TontineGroup @relation(fields: [groupId], references: [id])
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  role      TontineRole  @default(MEMBER)
  score     Float        @default(100)
  order     Int          @default(0)
  joinedAt  DateTime     @default(now())

  @@unique([groupId, userId])
}

enum TontineFrequency {
  HEBDOMADAIRE
  BIMENSUEL
  MENSUEL
}

enum TontineRole {
  ADMIN
  MEMBER
}

model Favorite {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  type      String
  targetId  String
  immoId    String?
  immo      ImmoListing? @relation(fields: [immoId], references: [id])
  jobId     String?
  job       JobPosting?  @relation(fields: [jobId], references: [id])
  marketId  String?
  market    MarketItem?  @relation(fields: [marketId], references: [id])
  createdAt DateTime     @default(now())

  @@unique([userId, type, targetId])
}

model Review {
  id          String       @id @default(cuid())
  note        Int
  commentaire String?
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  immoId      String?
  immo        ImmoListing? @relation(fields: [immoId], references: [id])
  createdAt   DateTime     @default(now())
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String
  titre       String
  message     String
  read        Boolean  @default(false)
  actionUrl   String?
  data        Json?
  createdAt   DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

// ─── Unified Listing & Extensions ────────────────────────────────────────────

enum ListingType {
  IMMOBILIER
  EMPLOI
  PRODUIT
  AGRI
  SERVICE
}

model Listing {
  id           String        @id @default(cuid())
  type         ListingType
  title        String
  description  String
  price        Float?
  devise       String        @default("USD")
  location     String?
  ville        String?
  province     String?
  latitude     Float?
  longitude    Float?
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  status       ListingStatus @default(ACTIVE)
  boosted      Boolean       @default(false)
  boostedUntil DateTime?
  vues         Int           @default(0)
  photos       String[]
  tags         String[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  realEstateDetails RealEstateDetails?
  jobDetails        JobDetails?
  productDetails    ProductDetails?
  agriDetails       AgriDetails?
  conversations     Conversation[]

  @@index([type, status])
  @@index([userId])
  @@index([ville, province])
  @@index([boosted, boostedUntil])
  @@index([createdAt])
}

model RealEstateDetails {
  id           String     @id @default(cuid())
  listingId    String     @unique
  listing      Listing    @relation(fields: [listingId], references: [id])
  action       ImmoAction
  surface      Int
  chambres     Int        @default(0)
  sallesBain   Int        @default(0)
  quartier     String
  meuble       Boolean    @default(false)
  parking      Boolean    @default(false)
  gardien      Boolean    @default(false)
  electrogen   Boolean    @default(false)
  eauChaude    Boolean    @default(false)
  internet     Boolean    @default(false)
  titreVerifie Boolean    @default(false)
  numFoncier   String?
}

model JobDetails {
  id          String    @id @default(cuid())
  listingId   String    @unique
  listing     Listing   @relation(fields: [listingId], references: [id])
  entreprise  String
  type        JobType
  categorie   String
  salaireMin  Float?
  salaireMax  Float?
  experience  String?
  competences String[]
  urgent      Boolean   @default(false)
  remote      Boolean   @default(false)
  expiresAt   DateTime?
}

model ProductDetails {
  id        String        @id @default(cuid())
  listingId String        @unique
  listing   Listing       @relation(fields: [listingId], references: [id])
  categorie String
  etat      ItemCondition
}

model AgriDetails {
  id           String  @id @default(cuid())
  listingId    String  @unique
  listing      Listing @relation(fields: [listingId], references: [id])
  produit      String
  quantite     Float
  unite        String
  prixUnitaire Float
  bio          Boolean @default(false)
  certifie     Boolean @default(false)
  disponible   Boolean @default(true)
}

// ─── Messaging ───────────────────────────────────────────────────────────────

model Conversation {
  id           String                    @id @default(cuid())
  listingId    String?
  listing      Listing?                  @relation(fields: [listingId], references: [id])
  lastMessage  String?
  lastMessageAt DateTime?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  participants ConversationParticipant[]
  messages     Message[]

  @@index([lastMessageAt])
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime?

  @@unique([conversationId, userId])
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  SYSTEM
  AUDIO
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  content        String
  type           MessageType  @default(TEXT)
  fileUrl        String?
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
  @@index([senderId])
}

// ─── Trust & Reputation ──────────────────────────────────────────────────────

enum TrustLevel {
  NEW
  BASIC
  VERIFIED
  TRUSTED
  PREMIUM
}

model TrustProfile {
  id                String     @id @default(cuid())
  userId            String     @unique
  user              User       @relation(fields: [userId], references: [id])
  score             Float      @default(0)
  level             TrustLevel @default(NEW)
  badges            String[]
  totalReviews      Int        @default(0)
  avgRating         Float      @default(0)
  totalTransactions Int        @default(0)
  verifiedPhone     Boolean    @default(false)
  verifiedEmail     Boolean    @default(false)
  verifiedId        Boolean    @default(false)
  verifiedBusiness  Boolean    @default(false)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
}

// ─── Moderation ──────────────────────────────────────────────────────────────

enum ReportReason {
  SPAM
  FRAUD
  INAPPROPRIATE
  FAKE_LISTING
  HARASSMENT
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

model Report {
  id          String       @id @default(cuid())
  reporterId  String
  reporter    User         @relation(fields: [reporterId], references: [id])
  targetType  String
  targetId    String
  reason      ReportReason
  description String?
  status      ReportStatus @default(PENDING)
  adminNote   String?
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime     @default(now())

  @@index([status])
  @@index([targetType, targetId])
}

// ─── Audit ───────────────────────────────────────────────────────────────────

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  action       String
  targetType   String?
  targetId     String?
  metadata     Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ─── Payments ────────────────────────────────────────────────────────────────

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentType {
  LISTING_BOOST
  PREMIUM_SUBSCRIPTION
  VERIFICATION_FEE
  LISTING_FEATURE
  DEPOSIT
  PURCHASE
  SUBSCRIPTION
  TRANSFER
  TONTINE
  INVOICE_PAYMENT
  API_USAGE
}

model PaymentIntent {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  amount          Float
  devise          String        @default("USD")
  provider        String?
  status          PaymentStatus @default(PENDING)
  type            PaymentType
  reference       String?       @unique
  idempotencyKey  String?       @unique
  providerRef     String?
  callbackUrl     String?
  expiresAt       DateTime?
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId, status])
  @@index([reference])
  @@index([providerRef])
}

// ─── Feature Flags ───────────────────────────────────────────────────────────

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  enabled     Boolean  @default(false)
  rolloutPct  Int      @default(100)
  modules     String[]
  cities      String[]
  countries   String[]
  roles       String[]
  planTiers   String[]
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Analytics ───────────────────────────────────────────────────────────────

model AnalyticsEvent {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  event       String
  properties  Json?
  sessionId   String?
  deviceType  String?
  locale      String?
  province    String?
  createdAt   DateTime @default(now())

  @@index([event])
  @@index([userId])
  @@index([createdAt])
  @@index([event, createdAt])
}

// ─── Geo ─────────────────────────────────────────────────────────────────────

enum GeoType {
  COUNTRY
  PROVINCE
  CITY
  QUARTIER
}

model GeoLocation {
  id         String        @id @default(cuid())
  name       String
  nameLocal  String?
  type       GeoType
  parentId   String?
  parent     GeoLocation?  @relation("GeoHierarchy", fields: [parentId], references: [id])
  children   GeoLocation[] @relation("GeoHierarchy")
  latitude   Float?
  longitude  Float?
  population Int?
  metadata   Json?

  @@index([type])
  @@index([parentId])
}

// ─── Background Jobs ─────────────────────────────────────────────────────────

enum JobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  RETRYING
  DEAD
}

model BackgroundJob {
  id          String    @id @default(cuid())
  queue       String
  type        String
  payload     Json
  status      JobStatus @default(QUEUED)
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  runAt       DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  error       String?
  createdAt   DateTime  @default(now())

  @@index([queue, status, runAt])
  @@index([type])
}
